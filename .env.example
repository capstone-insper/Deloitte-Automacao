# ─────────────────────────────────────────────────────────────────
# Variáveis de Ambiente - Dashboard Executivo Deloitte
# ─────────────────────────────────────────────────────────────────
# Copie este arquivo como .env e preencha os valores

# Chave secreta para autenticação (use um valor aleatório longo)
AUTH_SECRET=sua_chave_secreta_super_segura_aqui

# Caminho do banco de dados (opcional, padrão: users.db)
DB_PATH=users.db

# ─────────────────────────────────────────────────────────────────
# Senhas iniciais dos usuários
# Estas senhas são usadas apenas na primeira inicialização
# Deixe em branco para não criar o usuário automaticamente
# ─────────────────────────────────────────────────────────────────

# João Rocha - MASTER (será criado como master automaticamente)
INIT_PASSWORD_JOAOROCHA=sua_senha_joao_rocha

# João Heinke
INIT_PASSWORD_JOAOHEINKE=sua_senha_joao_heinke

# Alberto Carrera
INIT_PASSWORD_ALBERTOCARRERA=sua_senha_alberto_carrera

# Vitória Farias
INIT_PASSWORD_VITORIAFARIAS=sua_senha_vitoria_farias
